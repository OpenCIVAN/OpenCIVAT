{
  "name": "vtk-js-webpack-project",
  "version": "1.0.0",
  "description": "vtk.js visualization setup with Webpack and Babel",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "start:http": "USE_HTTP=true webpack serve --mode development --open",
    "build": "npm run build:manifests && webpack --mode production",
    "build:check": "webpack --mode development",
    "build:manifests": "ts-node scripts/buildManifestRegistry.ts",
    "prebuild": "npm run build:manifests",
    "server": "node server/src/index.js",
    "server:dev": "nodemon server/src/index.js",
    "websocket": "node server.js",
    "token-server": "node token-server.js",
    "livekit": "livekit-server --dev",
    "livekit:docker": "docker run --rm -p 7880:7880 -p 7881:7881 -p 7882:7882/udp livekit/livekit-server --dev",
    "livekit:start": "./scripts/start-livekit.sh",
    "livekit:stop": "./scripts/stop-livekit.sh",
    "dev": "concurrently \"npm:start\" \"npm:server:dev\" \"npm:websocket\"",
    "dev:http": "concurrently \"npm:start:http\" \"npm:server:dev\" \"npm:websocket\"",
    "dev:full": "concurrently \"npm:start\" \"npm:server:dev\" \"npm:websocket\" \"npm:token-server\" \"npm:livekit\"",
    "dev:full:http": "concurrently \"npm:start:http\" \"npm:server:dev\" \"npm:websocket\" \"npm:token-server\" \"npm:livekit\"",
    "dev:voice": "concurrently \"npm:token-server\" \"npm:livekit\"",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml up --build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.18.6",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-onboarding": "^10.0.8",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/react-webpack5": "^10.0.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.25",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-loader": "^8.4.1",
    "baseline-browser-mapping": "^2.9.17",
    "css-loader": "^7.1.2",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.4",
    "jsdom": "^27.4.0",
    "storybook": "^10.0.8",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "webpack": "^5.101.3",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.15.2",
    "webpack-glsl-loader": "^1.0.1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@kitware/vtk.js": "^34.16.2",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@tensorflow/tfjs": "^4.22.0",
    "bullmq": "^5.65.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.0.0",
    "livekit-client": "^1.15.0",
    "livekit-server-sdk": "^2.9.0",
    "lucide-react": "^0.440.0",
    "minio": "^7.1.3",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "three": "^0.175.0",
    "uuid": "^9.0.0",
    "vtk.js": "^24.19.2",
    "webxr-polyfill": "^2.0.3",
    "ws": "^8.18.1",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.27",
    "zustand": "^4.4.1"
  }
}
