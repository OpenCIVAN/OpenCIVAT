# .env.example - Copy to .env and fill in values
# DO NOT commit .env with real secrets!

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=ciauser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=cia_analytics
DATABASE_URL=postgresql://ciauser:change_me_in_production@postgres:5432/cia_analytics

# ===========================================
# API Configuration
# ===========================================
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:8081,https://localhost:8081
API_BASE_URL=http://localhost:3001

# ===========================================
# Keycloak Authentication
# ===========================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cia-web
KEYCLOAK_CLIENT_ID=cia-web-app
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production

# ===========================================
# MinIO Object Storage
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production

# ===========================================
# Y.js WebSocket
# ===========================================
YJS_WEBSOCKET_URL=ws://localhost:9001

# ===========================================
# Development Settings
# ===========================================
# Set to 'true' to skip Keycloak auth during development
DEV_BYPASS_AUTH=false

# Internal API token for worker callbacks (set to a strong random value)
INTERNAL_API_TOKEN=change_me_in_production

# ===========================================
# Matrix Federation (Optional)
# ===========================================
# Enable Matrix Protocol federation for cross-server chat
MATRIX_FEDERATION_ENABLED=true
MATRIX_BASE_URL=http://synapse:8008
MATRIX_SERVER_NAME=matrix.cia-web.local
MATRIX_AS_TOKEN=generate_secure_token_here
MATRIX_HS_TOKEN=generate_secure_token_here
MATRIX_POSTGRES_PASSWORD=change_me_in_production
