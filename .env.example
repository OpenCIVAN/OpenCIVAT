# .env.example - Copy to .env and fill in values
# DO NOT commit .env with real secrets!

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=ciauser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=cia_analytics
DATABASE_URL=postgresql://ciauser:change_me_in_production@postgres:5432/cia_analytics

# ===========================================
# API Configuration
# ===========================================
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:8081,https://localhost:8081
API_BASE_URL=http://localhost:3001

# ===========================================
# Keycloak Authentication
# ===========================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cia-web
KEYCLOAK_CLIENT_ID=cia-web-app
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production

# ===========================================
# MinIO Object Storage
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production

# ===========================================
# Y.js WebSocket
# ===========================================
YJS_WEBSOCKET_URL=ws://localhost:9001

# ===========================================
# Development Settings
# ===========================================
# Set to 'true' to skip Keycloak auth during development
DEV_BYPASS_AUTH=false

# Internal API token for worker callbacks (set to a strong random value)
INTERNAL_API_TOKEN=change_me_in_production

# ===========================================
# Server-Side Rendering (VTK Render Server)
# ===========================================
# Rendering mode: 'server' (Python VTK), 'local' (browser VTK.js), 'hybrid'
RENDER_MODE=server

# Python VTK render server base URL (HTTP)
RENDER_SERVER_URL=http://localhost:7001

# WebSocket URL for interactive frame streaming
# In dev, webpack proxies /render-ws → ws://localhost:7000/ws
RENDER_WS_URL=/render-ws

# Render resolution
RENDER_WIDTH=1024
RENDER_HEIGHT=768

# Maximum concurrent render sessions
MAX_SESSIONS=10

# Server-side dataset directory (mounted from public/vtp_files/ in Docker)
DATASET_DIR=./server/datasets

# Allowed file extensions for server dataset discovery
ALLOWED_DATASET_EXTENSIONS=.vtp,.vtu,.vti

# Maximum single dataset size in MB
MAX_DATASET_MB=1000

# ===========================================
# GPU Rendering (Windows/NVIDIA Docker)
# ===========================================
# Set true when running with docker-compose.gpu.yml override on NVIDIA hardware
ENABLE_GPU_RENDERING=false

# WebXR / browser capability flags
ENABLE_WEBXR=true
ENABLE_BROWSER_NAME_BLOCKING=false

# ===========================================
# Future AWS (do NOT set in dev — no keys in .env)
# ===========================================
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_RENDER_INSTANCE_TYPE=
# (Use IAM roles + Secrets Manager in production — never hardcode keys)

# ===========================================
# Matrix Federation (Optional)
# ===========================================
# Enable Matrix Protocol federation for cross-server chat
MATRIX_FEDERATION_ENABLED=true
MATRIX_BASE_URL=http://synapse:8008
MATRIX_SERVER_NAME=matrix.cia-web.local
MATRIX_AS_TOKEN=generate_secure_token_here
MATRIX_HS_TOKEN=generate_secure_token_here
MATRIX_POSTGRES_PASSWORD=change_me_in_production
