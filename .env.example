# .env.example
# Copy to .env before starting: cp .env.example .env
# These are working development defaults — no changes needed for local dev.
# DO NOT commit .env if you add real credentials (API keys, cloud secrets, etc.)

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=ciauser
POSTGRES_PASSWORD=ciadevpassword
POSTGRES_DB=cia_analytics
DATABASE_URL=postgresql://ciauser:ciadevpassword@localhost:5432/cia_analytics

# ===========================================
# API Configuration
# ===========================================
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:8081,https://localhost:8081
API_BASE_URL=http://localhost:3001

# ===========================================
# Keycloak Authentication
# ===========================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cia-web
KEYCLOAK_CLIENT_ID=cia-web-app
KEYCLOAK_ADMIN_PASSWORD=admin123

# ===========================================
# MinIO Object Storage
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===========================================
# Y.js WebSocket
# ===========================================
YJS_WEBSOCKET_URL=ws://localhost:9001

# ===========================================
# Development Settings
# ===========================================
# Set to 'true' to skip Keycloak auth checks during development
DEV_BYPASS_AUTH=false

# Internal API token for worker callbacks (set to a strong random value in production)
INTERNAL_API_TOKEN=dev-internal-token

# ===========================================
# Matrix Federation (Optional)
# ===========================================
# Enable Matrix Protocol federation for cross-server chat
MATRIX_FEDERATION_ENABLED=false
MATRIX_BASE_URL=http://synapse:8008
MATRIX_SERVER_NAME=matrix.cia-web.local
MATRIX_AS_TOKEN=generate_secure_token_here
MATRIX_HS_TOKEN=generate_secure_token_here
MATRIX_POSTGRES_PASSWORD=ciadevpassword
