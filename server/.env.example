# CIA Web Server Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# DATABASE CONFIGURATION (CIA Web Main Database)
# =============================================================================

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cia_web
DB_USER=cia_user
DB_PASSWORD=your-database-password-here

# Database pool settings (optional)
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT secret for session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-64-chars-minimum-here

# Session secret
SESSION_SECRET=your-session-secret-here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# MATRIX FEDERATION CONFIGURATION
# =============================================================================

# Matrix homeserver configuration
MATRIX_SERVER_NAME=matrix.cia-web.local
MATRIX_BASE_URL=http://localhost:8008

# Matrix PostgreSQL database (separate from CIA Web DB)
MATRIX_POSTGRES_PASSWORD=change-me-in-production

# Matrix Application Service tokens (must match cia-bridge-registration.yaml)
# Generate AS token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MATRIX_AS_TOKEN=CHANGE_ME_as_token_64_chars_long_random_hex_string_here_12345678

# Generate HS token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MATRIX_HS_TOKEN=CHANGE_ME_hs_token_64_chars_long_random_hex_string_here_87654321

# Matrix registration shared secret (for creating initial users via CLI)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MATRIX_REGISTRATION_SECRET=CHANGE_ME_registration_secret_64_chars_long_random_string_here

# Matrix federation settings
MATRIX_FEDERATION_ENABLED=true

# =============================================================================
# FILE STORAGE
# =============================================================================

# Upload directory for user files
UPLOAD_DIR=/data/uploads

# Max upload size (in bytes)
MAX_UPLOAD_SIZE=52428800  # 50MB

# =============================================================================
# LOGGING
# =============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log file path (optional, logs to console if not set)
LOG_FILE=/data/logs/cia-web.log

# =============================================================================
# Y.JS WEBSOCKET CONFIGURATION
# =============================================================================

# Y.js WebSocket port
YWEBSOCKET_PORT=1234

# Y.js persistence settings
YWEBSOCKET_PERSISTENCE=true

# =============================================================================
# REDIS CONFIGURATION (optional, for scaling)
# =============================================================================

# Redis connection (optional, used for session storage and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# VR/XR CONFIGURATION
# =============================================================================

# WebXR settings
WEBXR_ENABLED=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Mock external services (for testing)
MOCK_SERVICES=false

# =============================================================================
# NOTES
# =============================================================================

# To set up Matrix federation:
# 1. Copy this file to .env
# 2. Generate all CHANGE_ME tokens using the commands provided
# 3. Update matrix-config/homeserver.yaml with MATRIX_REGISTRATION_SECRET
# 4. Update matrix-config/cia-bridge-registration.yaml with MATRIX_AS_TOKEN and MATRIX_HS_TOKEN
# 5. Run: docker-compose -f docker-compose.matrix.yml up -d
# 6. See matrix-config/README.md for detailed setup instructions
