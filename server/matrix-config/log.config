# Synapse Logging Configuration
#
# This file configures Python's logging system for Synapse
# Reference: https://docs.python.org/3/library/logging.config.html

version: 1

formatters:
  precise:
    format: '%(asctime)s - %(name)s - %(lineno)d - %(levelname)s - %(request)s - %(message)s'

handlers:
  # Console output (captured by Docker)
  console:
    class: logging.StreamHandler
    formatter: precise
    stream: ext://sys.stdout

  # File output (persisted in /data volume)
  file:
    class: logging.handlers.RotatingFileHandler
    formatter: precise
    filename: /data/homeserver.log
    maxBytes: 104857600  # 100MB
    backupCount: 5
    encoding: utf8

  # Error log (only warnings and errors)
  error_file:
    class: logging.handlers.RotatingFileHandler
    formatter: precise
    filename: /data/homeserver-error.log
    maxBytes: 104857600  # 100MB
    backupCount: 3
    encoding: utf8
    level: WARNING

loggers:
  # Main synapse logger
  synapse:
    level: INFO
    handlers: [console, file, error_file]

  # Reduce noise from specific subsystems
  synapse.storage.SQL:
    level: WARNING

  synapse.http.server:
    level: WARNING

  synapse.metrics:
    level: WARNING

  # Federation traffic (useful for debugging)
  synapse.federation:
    level: INFO

  # Application service events (our bridge)
  synapse.appservice:
    level: INFO

  # Access logs (can be noisy)
  synapse.access:
    level: WARNING

  # Event processing
  synapse.events:
    level: INFO

  # Reduce third-party library noise
  twisted:
    level: WARNING

  urllib3:
    level: WARNING

root:
  level: INFO
  handlers: [console, file]

# Disable duplicate log lines
disable_existing_loggers: false
